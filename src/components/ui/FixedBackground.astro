---
interface Props {
  image: string;
  imageMobile?: string;
  imageDark?: string;
  imageMobileDark?: string;
  position?: string;
  positionMobile?: string;
  /** Difiere la descarga de las imágenes hasta que la sección se acerque
      al viewport. Usar en secciones below-the-fold (projects, footer). */
  lazy?: boolean;
  class?: string;
}

const {
  image,
  imageMobile,
  imageDark,
  imageMobileDark,
  position = "center",
  positionMobile,
  lazy = false,
  class: className,
} = Astro.props;

const toSet = (png: string) => {
  const avif = png.replace("/png/", "/avif/").replace(/\.(png|jpe?g)$/i, ".avif");
  const webp = png.replace("/png/", "/webp/").replace(/\.(png|jpe?g)$/i, ".webp");
  return `image-set(url("${avif}") type("image/avif"), url("${webp}") type("image/webp"), url("${png}") type("image/png"))`;
};

const desktopSet = toSet(image);
const mobileSet = toSet(imageMobile ?? image);
const hasDark = Boolean(imageDark || imageMobileDark);
const desktopSetDark = hasDark ? toSet(imageDark ?? image) : "";
const mobileSetDark = hasDark
  ? toSet(imageMobileDark ?? imageDark ?? imageMobile ?? image)
  : "";

const baseClasses = [
  "fixed top-0 left-0 -z-10 w-screen h-[var(--fb-h,100vh)]",
  "bg-[position:var(--bg-pos-mobile)] md:bg-[position:var(--bg-pos-desktop)]",
  "bg-cover bg-no-repeat transform-gpu backface-hidden brightness-[0.7]",
];

const positions = `--bg-pos-mobile: ${positionMobile ?? position}; --bg-pos-desktop: ${position}`;

// En modo lazy las image-sets van en data-* y un script las promueve a
// CSS vars cuando la sección se acerca al viewport (IntersectionObserver).
const lightStyle = lazy
  ? positions
  : `--bg-mobile: ${mobileSet}; --bg-desktop: ${desktopSet}; ${positions}`;
const darkStyle = lazy
  ? positions
  : `--bg-mobile-dark: ${mobileSetDark}; --bg-desktop-dark: ${desktopSetDark}; ${positions}`;
---

<!-- Capa light (base) -->
<div
  aria-hidden="true"
  class:list={[
    ...baseClasses,
    "light-ready:bg-[image:var(--bg-mobile)] md:light-ready:bg-[image:var(--bg-desktop)]",
    hasDark && "dark:opacity-0 transition-opacity duration-500 ease-in-out",
    className,
  ]}
  style={lightStyle}
  data-bg-lazy={lazy ? "" : undefined}
  data-bg-mobile={lazy ? mobileSet : undefined}
  data-bg-desktop={lazy ? desktopSet : undefined}
  data-bg-var="--bg-mobile"
  data-bg-var-desktop="--bg-desktop"
>
</div>

{
  /* Capa dark encima: cross-fade vía opacity (background-image no es animable).
     La imagen se aplica solo en dark para no descargarla en modo light. */
  hasDark && (
    <div
      aria-hidden="true"
      class:list={[
        ...baseClasses,
        "dark-ready:bg-[image:var(--bg-mobile-dark)] md:dark-ready:bg-[image:var(--bg-desktop-dark)]",
        "opacity-0 transition-opacity duration-500 ease-in-out dark:opacity-100",
        className,
      ]}
      style={darkStyle}
      data-bg-lazy={lazy ? "" : undefined}
      data-bg-mobile={lazy ? mobileSetDark : undefined}
      data-bg-desktop={lazy ? desktopSetDark : undefined}
      data-bg-var="--bg-mobile-dark"
      data-bg-var-desktop="--bg-desktop-dark"
    />
  )
}

<script>
  function initLazyBackgrounds(): void {
    const lazyDivs =
      document.querySelectorAll<HTMLElement>("[data-bg-lazy]");
    if (!lazyDivs.length) return;

    const reveal = (el: HTMLElement): void => {
      el.style.setProperty(el.dataset.bgVar!, el.dataset.bgMobile!);
      el.style.setProperty(el.dataset.bgVarDesktop!, el.dataset.bgDesktop!);
      delete el.dataset.bgLazy;
    };

    if (!("IntersectionObserver" in window)) {
      lazyDivs.forEach(reveal);
      return;
    }

    // Se observa la sección contenedora: el div es position:fixed y para
    // el observer siempre estaría "en viewport".
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target
            .querySelectorAll<HTMLElement>("[data-bg-lazy]")
            .forEach(reveal);
          observer.unobserve(entry.target);
        }
      },
      { rootMargin: "75% 0px" },
    );

    const sections = new Set<Element>();
    lazyDivs.forEach((div) => {
      if (div.parentElement) sections.add(div.parentElement);
    });
    sections.forEach((section) => observer.observe(section));
  }

  document.addEventListener("astro:page-load", initLazyBackgrounds);
</script>
