---
import type { Project } from "@/types";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article
  data-project={JSON.stringify(project)}
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  class="group cursor-pointer overflow-hidden rounded-lg border-2 border-white/10 bg-neutral-900/90 shadow-[6px_6px_0_rgba(0,0,0,0.35)] transition-colors duration-300 hover:border-orange-400/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400"
>
  <div class="overflow-hidden">
    <img
      src={project.image}
      alt={project.title}
      loading="lazy"
      decoding="async"
      class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <h3
    class="font-orbitron px-4 py-3 text-center text-sm font-semibold tracking-wide text-amber-50 sm:text-base lg:py-4 lg:text-lg"
  >
    {project.title}
  </h3>
</article>
