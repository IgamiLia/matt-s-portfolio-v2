---
import FixedBackground from "@ui/FixedBackground.astro";
---

<main
  id="home"
  class="relative -mt-20 h-70 md:h-100 w-full overflow-hidden [clip-path:inset(0)] [--fb-h:17.5rem] md:[--fb-h:25rem]"
>
  <FixedBackground
    image="/backgrounds/png/bg-header.png"
    imageDark="/backgrounds/dark/png/bg-hero-dark.png"
    imageMobileDark="/backgrounds/dark/png/bg-hero-dark-mobile.png"
    position="center 70%"
    positionMobile="center 72%"
  />

  <div
    aria-hidden="true"
    data-hero-sky
    class="fixed top-0 left-0 -z-10 h-[var(--fb-h,100vh)] w-screen overflow-hidden transition-opacity duration-500 ease-in-out dark:opacity-0"
  >
    <img
      src="/sprites/png/sun.png"
      alt=""
      width="256"
      height="256"
      decoding="async"
      class="absolute top-[30%] md:top-[12%] right-[8%] h-auto w-12 md:w-48 drop-shadow-[0_0_16px_rgba(255,255,255,1)] hidden"
    />
  </div>

  <div
    class="group absolute bottom-0 left-1/2 flex w-full -translate-x-1/2 items-end justify-center px-4 sm:px-6 lg:px-8"
  >
    <picture class="contents">
      <source srcset="/sprites/avif/matt.avif" type="image/avif" />
      <source srcset="/sprites/webp/matt.webp" type="image/webp" />
      <img
        src="/sprites/png/matt.png"
        alt=""
        aria-hidden="true"
        width="798"
        height="800"
        decoding="async"
        class="absolute z-5 -mb-1 translate-x-[-50%] md:translate-x-[-65%] -mr-8 w-44 h-auto -rotate-3 drop-shadow-[-8px_8px_16px_rgba(0,0,0,0.45)] transition-transform duration-500 ease-in-out group-hover:translate-y-full sm:-mr-12 sm:w-60 md:-mr-16 md:w-80"
      />
    </picture>
    <h1
      class="text-6xl font-black translate-x-15 md:translate-x-25 tracking-tighter text-white uppercase [text-shadow:-5px_5px_0_rgba(0,0,0,0.35)] transition-all duration-500 ease-in-out group-hover:translate-x-0 group-hover:scale-200 group-hover:translate-y-[-50%] sm:text-8xl lg:text-9xl"
    >
      MATT
    </h1>
  </div>
</main>

<style is:global>
  .hero-cloud {
    left: 0;
    animation: hero-cloud-drift 60s linear infinite;
  }

  @keyframes hero-cloud-drift {
    from {
      translate: -300px 0;
    }
    to {
      translate: calc(100vw + 60px) 0;
    }
  }
</style>

<script>
  const CLOUD_COUNT_DESKTOP = 28;
  const CLOUD_COUNT_MOBILE = 16;

  function initHeroSky(): void {
    const sky = document.querySelector<HTMLElement>("[data-hero-sky]");
    if (!sky || sky.querySelector(".hero-cloud")) return;

    const isDesktop = matchMedia("(min-width: 768px)").matches;
    const count = isDesktop ? CLOUD_COUNT_DESKTOP : CLOUD_COUNT_MOBILE;

    for (let i = 0; i < count; i++) {
      const cloud = document.createElement("img");
      const duration = 40 + Math.random() * 40;

      cloud.src = "/sprites/png/cloud.png";
      cloud.alt = "";
      cloud.width = 128;
      cloud.height = 64;
      cloud.decoding = "async";
      cloud.className = "hero-cloud absolute h-auto w-32 ";
      cloud.style.top = `${5 + Math.random() * 80}%`;
      cloud.style.scale = isDesktop
        ? String(0.6 + Math.random() * 2.5)
        : String(0.5 + Math.random() * 0.8);
      cloud.style.opacity = String(0.7 + Math.random() * 0.3);
      cloud.style.animationDuration = `${duration}s`;
      cloud.style.animationDelay = `-${Math.random() * duration}s`;

      sky.append(cloud);
    }
  }

  document.addEventListener("astro:page-load", initHeroSky);
</script>
