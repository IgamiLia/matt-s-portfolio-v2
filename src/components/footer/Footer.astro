---
import FixedBackground from "@ui/FixedBackground.astro";
import { socials } from "@data/socials";
---

<footer
  class="relative w-full overflow-hidden px-4 py-16 text-center text-amber-50 [clip-path:inset(0)] sm:px-6 sm:py-24 lg:py-32"
>
  <FixedBackground
    image="/backgrounds/bg-footer.png"
    imageMobile="/backgrounds/bg-footer-mobile.png"
  />

  <h2
    class="font-orbitron text-2xl font-bold tracking-tight [text-shadow:3px_3px_0_rgba(0,0,0,0.45)] sm:text-3xl lg:text-4xl"
  >
    Construyamos algo memorable
  </h2>

  <nav class="mt-8 sm:mt-10" aria-label="Redes sociales">
    <ul
      class="mx-auto grid w-fit grid-cols-2 justify-items-start gap-x-8 gap-y-2 sm:grid-cols-3 lg:flex lg:items-center lg:justify-center lg:gap-8"
    >
      {
        socials.map(({ label, url, icon }) => (
          <li>
            <a
              href={url}
              target={url.startsWith("mailto:") ? undefined : "_blank"}
              rel={
                url.startsWith("mailto:") ? undefined : "noopener noreferrer"
              }
              class="flex items-center gap-2.5 rounded-md px-2 py-2.5 text-base font-medium transition-colors hover:text-orange-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400 sm:text-lg lg:gap-3 lg:px-3 lg:text-xl"
            >
              <img
                src={icon}
                alt=""
                aria-hidden="true"
                loading="lazy"
                decoding="async"
                class="h-6 w-6 sm:h-7 sm:w-7 lg:h-8 lg:w-8"
              />
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <p class="mt-10 text-sm text-amber-50/80 sm:mt-14 sm:text-base">
    &copy; 2026 <a href="/" class="underline underline-offset-2">Matt</a>. Derechos
    reservados.
  </p>
</footer>
