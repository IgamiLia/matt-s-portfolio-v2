---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/hero/Hero.astro";
import HeroAbout from "@components/about/HeroAbout.astro";
import FooterAbout from "@components/about/FooterAbout.astro";
import FeaturedSection from "@sections/FeaturedSection.astro";
import ProjectModal from "@components/ProjectModal.astro";
---

<BaseLayout
  title="Matt - Desarrollador Web Frontend"
  description="Bienvenido al portafolio de Matías Aguirre, desarrollador web frontend de Buenos Aires. Explora proyectos hechos con Astro, JavaScript y TypeScript, enfocados en experiencias únicas y memorables."
>
  <Fragment slot="head">
    <!-- Preloads estáticos: visibles para el preload scanner (crítico para LCP).
         Gateados por viewport + prefers-color-scheme; si el usuario forzó un tema
         distinto al del SO se precarga uno de más, tradeoff aceptable. -->
    <link
      rel="preload"
      as="image"
      href="/backgrounds/avif/bg-header-gradient.avif"
      type="image/avif"
      fetchpriority="high"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="preload"
      as="image"
      href="/backgrounds/dark/avif/bg-hero-dark.avif"
      type="image/avif"
      fetchpriority="high"
      media="(min-width: 768px) and (prefers-color-scheme: dark)"
    />
    <link
      rel="preload"
      as="image"
      href="/backgrounds/dark/avif/bg-hero-dark-mobile.avif"
      type="image/avif"
      fetchpriority="high"
      media="(max-width: 767.98px) and (prefers-color-scheme: dark)"
    />
  </Fragment>

  <Hero />
  <HeroAbout />
  <FeaturedSection />
  <ProjectModal />
  <FooterAbout />
</BaseLayout>
