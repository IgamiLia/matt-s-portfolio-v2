---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/hero/Hero.astro";
import HeroAbout from "@components/about/HeroAbout.astro";
import FooterAbout from "@components/about/FooterAbout.astro";
import FeaturedSection from "@sections/FeaturedSection.astro";
import ProjectModal from "@components/ProjectModal.astro";
---

<BaseLayout
  title="Matt - Desarrollador Web Frontend"
  description="Bienvenido al portafolio de Matías Aguirre, desarrollador web frontend de Buenos Aires. Explora proyectos hechos con Astro, JavaScript y TypeScript, enfocados en experiencias únicas y memorables."
>
  <Fragment slot="head">
    <!-- Preload theme-aware del hero: corre tras el script anti-FOUC del layout -->
    <script is:inline>
      (() => {
        const dark = document.documentElement.dataset.theme === "dark";
        const desktop = matchMedia("(min-width: 768px)").matches;
        const base = dark
          ? "/backgrounds/dark/avif/bg-hero-dark"
          : "/backgrounds/avif/bg-header";
        const link = document.createElement("link");
        link.rel = "preload";
        link.as = "image";
        link.type = "image/avif";
        link.href = `${base}${desktop ? "" : "-mobile"}.avif`;
        document.head.append(link);
      })();
    </script>
  </Fragment>

  <Hero />
  <HeroAbout />
  <FeaturedSection />
  <ProjectModal />
  <FooterAbout />
</BaseLayout>
